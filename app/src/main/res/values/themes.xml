<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.RecipeGenie" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_light</item>
        <item name="colorOnSecondary">@color/orange_dark</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/orange_primary</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Theme.RecipeGenie.Splash" parent="Theme.RecipeGenie">
        <item name="android:statusBarColor">@color/orange_extra_light</item>
        <item name="android:windowBackground">@color/orange_extra_light</item>
    </style>

    <style name="Theme.RecipeGenie.CookMode" parent="Theme.RecipeGenie">
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
    </style>

    <style name="ShapeAppearance.Circle" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.RecipeGenie.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.RecipeGenie.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/orange_primary</item>
        <item name="android:textColor">@color/orange_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.RecipeGenie.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/gray_text</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <!-- EditText Style -->
    <style name="Widget.RecipeGenie.EditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxStrokeColor">@color/gray_border</item>
        <item name="boxBackgroundColor">@color/gray_bg</item>
        <item name="hintTextColor">@color/gray_hint</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.RecipeGenie.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/gray_border</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.RecipeGenie.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/gray_bg</item>
        <item name="android:textColor">@color/gray_dark</item>
        <item name="chipStrokeColor">@color/gray_border</item>
        <item name="chipStrokeWidth">0.5dp</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.RecipeGenie.Chip.Selected" parent="Widget.RecipeGenie.Chip">
        <item name="chipBackgroundColor">@color/orange_extra_light</item>
        <item name="android:textColor">@color/orange_dark</item>
        <item name="chipStrokeColor">@color/orange_primary</item>
        <item name="chipStrokeWidth">1.5dp</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.RecipeGenie.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
    </style>

    <style name="TextAppearance.RecipeGenie.Subtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/gray_text</item>
    </style>

    <style name="TextAppearance.RecipeGenie.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

</resources>
