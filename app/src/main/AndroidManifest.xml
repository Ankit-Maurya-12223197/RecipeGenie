<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".RecipeGenieApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecipeGenie"
        tools:targetApi="31">
        <activity
            android:name=".SignUpActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <!-- ── Splash Screen ─────────────────────────────────────────────── -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.RecipeGenie.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- ── Auth ──────────────────────────────────────────────────────── -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" /> <!-- ── Main (bottom nav host) ────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" /> <!-- ── Recipe Detail ─────────────────────────────────────────────── -->
        <activity
            android:name=".RecipeDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait" /> <!-- ── Cook Mode  (keep screen on, portrait only) ────────────────── -->
        <activity
            android:name=".CookModeActivity"
            android:exported="false"
            android:keepScreenOn="true"
            android:parentActivityName=".RecipeDetailActivity"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:theme="@style/Theme.RecipeGenie.CookMode"
            android:turnScreenOn="true" /> <!-- ── AI Chef Chat ───────────────────────────────────────────────── -->
        <activity
            android:name=".AiChefActivity"
            android:exported="false"
            android:parentActivityName=".RecipeDetailActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" /> <!-- Google Sign-In metadata -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
    </application>

</manifest>
